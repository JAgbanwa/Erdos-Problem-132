import itertools
import random

def distances_and_counts(points):
    """Return dict: distance -> number of pairs at that distance."""
    n = len(points)
    counts = {}
    for i in range(n):
        xi, yi = points[i]
        for j in range(i+1, n):
            xj, yj = points[j]
            d = (xi - xj)**2 + (yi - yj)**2  # squared distance, to avoid float issues
            counts[d] = counts.get(d, 0) + 1
    return counts

def has_at_least_two_distances_up_to_n(points):
    n = len(points)
    counts = distances_and_counts(points)
    # Distances with count between 1 and n inclusive
    good_distances = [d for d, c in counts.items() if 1 <= c <= n]
    return len(good_distances) >= 2

def test_random_points(num_tests=1000, n=8):
    for _ in range(num_tests):
        points = [(random.random(), random.random()) for __ in range(n)]
        if not has_at_least_two_distances_up_to_n(points):
            print("Found counterexample for n =", n, points)
            return False
    return True

# Quick test
print("Testing small n...")
for n in range(4, 11):
    ok = test_random_points(num_tests=200, n=n)
    print(f"n={n}: no counterexample found in random tests" if ok else f"n={n}: counterexample found")
